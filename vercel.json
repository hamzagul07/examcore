{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/mark/whole-paper/run/route.ts": {
      "maxDuration": 800
    },
    "app/api/mark/process/route.ts": {
      "maxDuration": 800
    },
    "app/api/omni-ai/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/community-digest/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/community-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/review-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/visitor-digest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/page-events-cleanup",
      "schedule": "0 4 * * 0"
    }
  ]
}
