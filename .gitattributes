# Normalize line endings across Windows, macOS, and Linux.
* text=auto eol=lf

# Shell and config
*.sh text eol=lf
*.bash text eol=lf
.env.example text eol=lf

# Windows-only scripts (if added later)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
