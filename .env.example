# Copy to .env.local and fill in. NEVER commit real keys (.env.local is gitignored).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Pro — optional but recommended (Dashboard settings, not app runtime):
# • Auth → Providers → Google: enable, add OAuth client ID/secret from Google Cloud Console
# • Auth → URL configuration: Site URL + Redirect URLs must include:
#     https://markscheme.app/auth/callback
#     http://localhost:3000/auth/callback
#     (and your Vercel preview URL while testing)
# • Auth → Password security → enable "Leaked password protection" (HaveIBeenPwned)
# • Auth → SMTP → custom SMTP for magic links / OTP (better deliverability than default)
# • Database → Backups → point-in-time recovery is included on Pro
# • Database → Connection pooling → Transaction mode URL for scripts/CLI only:
#   SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Resend (transactional + admin alerts) — https://resend.com ---
# Verify markscheme.app in Resend, then:
# RESEND_API_KEY=re_...
# RESEND_FROM=MarkScheme <hello@markscheme.app>
# RESEND_REPLY_TO=hello@markscheme.app
# CONTACT_NOTIFY_TO=hello@markscheme.app
# SUPABASE_ACCESS_TOKEN=sbp_...   # for scripts/configure-supabase-smtp.mjs only
# See docs/EMAIL_SETUP.md (welcome, purchases, contact, Supabase SMTP for magic links)

# Comma-separated emails allowed to access /admin (defaults to owner if unset)
# ADMIN_EMAILS=you@example.com,ops@example.com

# --- AI (Google Gemini — marking, chat, OCR, course generation) ---
# Backend A — Vertex AI (recommended for production: Dynamic Shared Quota, no daily cap)
# USE_VERTEX_AI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# Local: path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/vertex-service-account.json
# Vercel/production: paste the full JSON (no file path on serverless)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# See docs/vertex-ai-migration.md

# Backend B — Gemini API (fallback / local dev)
# Pro: gemini-2.5-pro | Flash: gemini-2.5-flash
GEMINI_API_KEY=...

# --- PDF extraction (Prompt C) ---
# Primary: Gemini Pro (default). Mathpix is feature-flagged off.
EXTRACTION_USE_MATHPIX=false
# Optional Mathpix revival — https://accounts.mathpix.com/
# MATHPIX_APP_ID=...
# MATHPIX_APP_KEY=...

# --- Polar (payments — Merchant of Record) — https://polar.sh ---
# Use SANDBOX first (https://sandbox.polar.sh), then flip POLAR_SERVER=production.
POLAR_SERVER=sandbox
# Organization Access Token (Settings → Developers). Grants products/checkouts/customers scopes.
POLAR_ACCESS_TOKEN=polar_oat_...
# Signing secret from the webhook endpoint you create (Settings → Webhooks),
# pointing at https://<your-domain>/api/billing/polar-webhook.
# Subscribe to ALL handled events: order.paid, order.refunded,
# subscription.created, subscription.active, subscription.updated,
# subscription.canceled, subscription.uncanceled, subscription.past_due,
# subscription.revoked.
POLAR_WEBHOOK_SECRET=
# Product IDs — create products with: node scripts/setup-polar-products.mjs
POLAR_PRODUCT_STUDENT_MONTHLY=
POLAR_PRODUCT_STUDENT_YEARLY=
POLAR_PRODUCT_SCHOLAR_MONTHLY=
POLAR_PRODUCT_SCHOLAR_YEARLY=
POLAR_PRODUCT_MASTERY_MONTHLY=
POLAR_PRODUCT_MASTERY_YEARLY=
POLAR_PRODUCT_CREDITS_25=
POLAR_PRODUCT_CREDITS_100=
POLAR_PRODUCT_CREDITS_500=

# Canonical site URL for sitemap, OG tags, auth redirects, and Polar return URLs.
# On Vercel without a custom domain, you can omit this — VERCEL_URL is used automatically.
# Set once markscheme.app DNS is live (must include https://):
# NEXT_PUBLIC_SITE_URL=https://markscheme.app
# Wrong: markscheme.app or https://markscheme.app/ (trailing slash is ok — we strip it)

# --- Sentry (optional — GitHub Student Pack: https://education.github.com/pack) ---
# Create a Next.js project at https://sentry.io → Settings → Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_DSN=https://...@....ingest.sentry.io/...
# For readable stack traces in prod (optional):
# SENTRY_ORG=your-org
# SENTRY_PROJECT=markscheme
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Exam Room (community) — enable after running the community migrations ---
# (20260623_community_exam_room.sql + 20260624_community_reddit.sql) ---
COMMUNITY_ENABLED=true
NEXT_PUBLIC_COMMUNITY_ENABLED=true

# --- Cron (Vercel sets Authorization: Bearer automatically when CRON_SECRET is set) ---
# CRON_SECRET=generate-a-long-random-string
# UNSUBSCRIBE_SECRET=optional-separate-secret-for-email-unsubscribe-links

# --- Email (Resend) — required for community reply + digest emails ---
# RESEND_API_KEY=re_...
# RESEND_FROM="MarkScheme <hello@markscheme.app>"

# --- Enforcement (Sprint 43 soft launch) ---
# Enforcement mode: 'off' | 'warn' | 'enforce'
# Soft launch: 'off' → verify metering (~3 days) → 'warn' → verify UX (~3 days) → 'enforce'
ENFORCEMENT_MODE=warn

# --- Pricing ---
# Prices live on Polar products. Edit amounts in scripts/setup-polar-products.mjs
# + lib/polar/products.ts (DISPLAY_PRICES_USD), then re-run:
#   node scripts/setup-polar-products.mjs

# --- Search Console verification (optional — injected via lib/seo/metadata.ts) ---
# GOOGLE_SITE_VERIFICATION=
# BING_SITE_VERIFICATION=
# YANDEX_VERIFICATION=

# --- Brand social (Organization.sameAs + footer — defaults in lib/seo/entity.ts) ---
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/markscheme.app
# NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@markscheme
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/MarkSchemeApp
# NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@MarkSchemeApp
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/markscheme/
# NEXT_PUBLIC_WIKIDATA_ENTITY_URL=https://www.wikidata.org/wiki/Q140455387

# --- GEO / IndexNow (optional — ping search engines after deploy) ---
# Generate a UUID key, host at public/{key}.txt (see public/38b35898-27c4-429b-a43e-b28fa420ffca.txt), then:
# INDEXNOW_KEY=38b35898-27c4-429b-a43e-b28fa420ffca
# SITE_HOST=markscheme.app
# pnpm seo:indexnow
