# Copy to .env.local and fill in. NEVER commit real keys (.env.local is gitignored).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Pro — optional but recommended (Dashboard settings, not app runtime):
# • Auth → Password security → enable "Leaked password protection" (HaveIBeenPwned)
# • Auth → SMTP → custom SMTP for magic links / OTP (better deliverability than default)
# • Database → Backups → point-in-time recovery is included on Pro
# • Database → Connection pooling → Transaction mode URL for scripts/CLI only:
#   SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional — contact form admin alerts (https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM=Examcore <notifications@examcore.ai>
# CONTACT_NOTIFY_TO=hello@examcore.ai

# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# --- Stripe (Sprint 42 — use TEST mode keys for now) ---
# Secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Signing secret from your webhook endpoint config (Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Enforcement (Sprint 43 soft launch) ---
# Enforcement mode: 'off' | 'warn' | 'enforce'
# Soft launch starts at 'off' — metering runs but no UI prompts or blocking.
# Progress to 'warn' after verifying counts are accurate (~3 days),
# then 'enforce' after verifying warn behavior is clean (~3 more days).
ENFORCEMENT_MODE=off
