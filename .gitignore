# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# syllabus PDFs (build-time inputs; extracted JSON in lib/syllabi/ is committed)
/syllabi-source/

# Private revision notes for Gemini enrichment (see content/source-notes/README.md)
/content/source-notes/**
!/content/source-notes/README.md
!/content/source-notes/.gitkeep

# Pre-Senpai lesson backups (local only)
/content/courses/**/_backup-pre-senpai/
/content/courses/**/_backup-pre-alnotes/
/content/source-notes/**/_alnotes-import/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the placeholder example IS committed so contributors know what to set
!.env.example

# Mathpix sample outputs (regenerate via scripts/mathpix-sample-papers.mjs)
scripts/mathpix-samples/

# Extraction dry-run outputs (scripts/extract-question-paper.mjs)
scripts/extraction-output/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Debug/QA artifacts — never commit these
_imported/
screenshots/
.chrome-*/
.chrome-profile/
.chrome-inspect/
chrome-user-data/

